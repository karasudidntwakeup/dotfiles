// Place this inside your matugen templates directory
// Location: ~/.config/matugen/templates/config.kdl

layout {
    // Gap sizes
    gaps 16

    // Configure the border thickness and colors using Matugen variables
    border {
        off
        width 4
        // Active border using primary color
        active-color "#bac3ff"
        // Inactive border using a subtle surface or outline color
        inactive-color "#46464f"
    }

    // Alternatively, if you prefer a subtle focus-ring instead of full borders:
    focus-ring {
        // omni
        width 0.0
        active-color "#bac3ff"
        inactive-color "#34343a"
    }
}
